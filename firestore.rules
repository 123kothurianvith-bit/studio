/**
 * @fileoverview Firestore Security Rules for Snapter Games.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user-specific data (profiles, wishlists)
 * and a public-read, owner-write model for published games.
 *
 * Data Structure:
 * - /users/{userId}: Stores user account information.
 * - /users/{userId}/wishlists/{wishlistId}: Stores user's wishlists.
 * - /games/{gameId}: Stores general game information (publicly readable).
 * - /publishedGames/{gameId}: Stores games published by developers.
 *
 * Key Security Decisions:
 * - Users can only access their own user data and wishlists.
 * - Published games are publicly readable but can only be created, updated, or deleted by the publisher.
 * - Listing of user documents and wishlists is allowed only for the owner.
 * - The rules explicitly deny any unauthorized access.
 *
 * Denormalization for Authorization:
 * - Wishlists are stored as subcollections of users for simplified authorization. The `userId` is implied by the path.
 * - Published games have a `publisherId` field that MUST match the authenticated user's UID for write operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user accounts.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their own account.
     * @allow (get, list, update, delete) User with UID 'user123' can read and modify their own account.
     * @deny (create, get, list, update, delete) User with UID 'otherUser' cannot access 'user123' account.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      // Helper function to check if the user is signed in and owns the document.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Allow the user to create their own document if the userId matches their auth UID.
      allow create: if isOwner(userId) && request.resource.data.id == userId;

      // Allow read access if the user is the owner.
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Allow update and delete access if the user is the owner and the document exists.
      allow update: if isOwner(userId) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces access control for wishlists.
     * @path /users/{userId}/wishlists/{wishlistId}
     * @allow (create) User with UID 'user123' can create a wishlist under their account.
     * @allow (get, list, update, delete) User with UID 'user123' can read and modify wishlists under their account.
     * @deny (create, get, list, update, delete) User with UID 'otherUser' cannot access wishlists under 'user123' account.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/wishlists/{wishlistId} {
      // Helper function to check if the user is signed in and owns the wishlist.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Allow create access if the user is the owner.
      allow create: if isOwner(userId);

      // Allow read access if the user is the owner.
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Allow update and delete access if the user is the owner and the document exists.
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Allows public read access to game information, but restricts write access.
     * @path /games/{gameId}
     * @allow (get, list) Any user can read game information.
     * @deny (create, update, delete) Only database administrators can create, update, or delete games (Placeholder - no implementation).
     * @principle Allows public read access with restricted write access (Placeholder).
     */
    match /games/{gameId} {
      // Allow public read access.
      allow get, list: if true;

      //  TODO: Add admin validation or other write restrictions.
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to published games, but restricts write access to the publisher.
     * @path /publishedGames/{gameId}
     * @allow (get, list) Any user can read published game information.
     * @allow (create) Publisher with UID 'publisher123' can create a published game with publisherId 'publisher123'.
     * @allow (update, delete) Publisher with UID 'publisher123' can update/delete their own published game.
     * @deny (create) Publisher with UID 'publisher123' cannot create a published game with publisherId 'otherUser'.
     * @deny (update, delete) User with UID 'otherUser' cannot update/delete published games of 'publisher123'.
     * @principle Allows public read access with owner-only writes.
     */
    match /publishedGames/{gameId} {
      // Allow public read access.
      allow get, list: if true;

      // Allow create access if the publisherId matches the authenticated user's UID.
      allow create: if request.auth != null && request.resource.data.publisherId == request.auth.uid;

      // Allow update and delete access if the publisherId matches the authenticated user's UID and the document exists.
      allow update: if request.auth != null && resource != null && resource.data.publisherId == request.auth.uid;
      allow delete: if request.auth != null && resource != null && resource.data.publisherId == request.auth.uid;
    }
  }
}