/**
 * @file Firebase Security Rules for Snapter Games
 * @description This ruleset enforces a user-ownership model for private user data, allows public read access to game data,
 * and restricts write access to specific roles or owners.
 *
 * @dataStructure
 * - /users/{userId}: Stores private user account data. Only the user can read/write their own data.
 * - /users/{userId}/wishlists/{wishlistId}: Stores user wishlists. Only the owning user can manage their wishlists.
 * - /games/{gameId}: Stores public game data. Publicly readable.
 * - /publishedGames/{gameId}: Stores published games. Publicly readable, but only the publisher can modify.
 * - /developers/{developerId}: Stores developer profiles. Publicly readable, but only the developer can modify their own profile.
 *
 * @keySecurityDecisions
 * - Users can only access their own data under /users/{userId}.
 * - Listing of all users is disallowed.
 * - Public read access is granted to the /games and /publishedGames and /developers collections.
 * - Ownership is enforced using path-based matching and denormalized `publisherId` and `developerId` fields.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for user account data.
     * @path /users/{userId}
     * @allow (create) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can create a document with ID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2'.
     * @allow (get) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can read their own document.
     * @allow (update) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can update their own document.
     * @allow (delete) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can delete their own document.
     * @deny (create) User with UID 'attackerId' cannot create a document with ID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2'.
     * @deny (get) User with UID 'attackerId' cannot read user 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' document.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing all users is not permitted

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for wishlists within a user's profile.
     * @path /users/{userId}/wishlists/{wishlistId}
     * @allow (create) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can create a wishlist under their own user ID.
     * @allow (get) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can read their own wishlist.
     * @allow (update) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can update their own wishlist.
     * @allow (delete) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can delete their own wishlist.
     * @deny (create) User with UID 'attackerId' cannot create a wishlist under user 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2'.
     * @deny (get) User with UID 'attackerId' cannot read wishlist of user 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2'.
     * @principle Restricts wishlist access to the owning user.
     */
    match /users/{userId}/wishlists/{wishlistId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to game information.
     * @path /games/{gameId}
     * @allow (get) Any user (or unauthenticated user) can read game data.
     * @allow (list) Any user (or unauthenticated user) can list games.
     * @deny (create) No one can create game documents without authorization. // TODO: Add role-based access control.
     * @principle Grants public read access to game data.
     */
    match /games/{gameId} {
      allow get: if true;
      allow list: if true;

      allow create: if false;  // TODO: Add role-based access control.
      allow update: if false;  // TODO: Add role-based access control.
      allow delete: if false;  // TODO: Add role-based access control.
    }

    /**
     * @description Allows public read access to published game information, but restricts write access to the publisher.
     * @path /publishedGames/{gameId}
     * @allow (get) Any user can read published game data.
     * @allow (list) Any user can list published games.
     * @allow (create) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can create a published game if they are the publisher.
     * @allow (update) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can update a published game if they are the publisher.
     * @allow (delete) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can delete a published game if they are the publisher.
     * @deny (create) User with UID 'attackerId' cannot create a published game with publisherId 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2'.
     * @deny (update) User with UID 'attackerId' cannot update a published game with publisherId 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2'.
     * @principle Grants public read access but enforces ownership for writes.
     */
    match /publishedGames/{gameId} {
      allow get: if true;
      allow list: if true;

      allow create: if request.resource.data.game.publisherId == request.auth.uid;
      allow update: if resource.data.game.publisherId == request.auth.uid && resource != null;
      allow delete: if resource.data.game.publisherId == request.auth.uid && resource != null;
    }

    /**
     * @description Allows public read access to developer profiles, but restricts write access to the developer.
     * @path /developers/{developerId}
     * @allow (get) Any user can read a developer profile.
     * @allow (list) Any user can list developer profiles.
     * @allow (create) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can create their own developer profile.
     * @allow (update) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can update their own developer profile.
     * @allow (delete) User with UID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2' can delete their own developer profile.
     * @deny (create) User with UID 'attackerId' cannot create a developer profile with ID 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2'.
     * @deny (update) User with UID 'attackerId' cannot update developer profile 'B6Mdc0YwWwTwR1ujSOQ6IuMHAjG2'.
     * @principle Grants public read access but enforces ownership for writes.
     */
    match /developers/{developerId} {
      allow get: if true;
      allow list: if true;

      allow create: if isOwner(developerId);
      allow update: if isExistingOwner(developerId);
      allow delete: if isExistingOwner(developerId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}